# ==============================================================================
# Configuração para Teste Local com Docker
# ==============================================================================

# ==============================================================================
# Database (PostgreSQL local no Windows)
# ==============================================================================
# Use host.docker.internal para acessar o PostgreSQL rodando no host Windows
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=enviafolha_db
DB_USER=enviafolha_user
DB_PASSWORD=secure_password

# ==============================================================================
# Evolution API (WhatsApp Integration)
# ==============================================================================
EVOLUTION_SERVER_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-api-key-here
EVOLUTION_INSTANCE_NAME=your-instance-name

# ==============================================================================
# JWT Authentication
# ==============================================================================
SECRET_KEY=your-secret-key-from-current-env

# ==============================================================================
# Application Configuration
# ==============================================================================
LOG_LEVEL=info
PORT=8002
API_URL=http://localhost:8002/api/v1

# ==============================================================================
# Docker Hub
# ==============================================================================
DOCKER_USERNAME=lucasplcorrea
TAG=latest
