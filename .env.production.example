# ==============================================================================
# Arquivo de Exemplo - Variáveis de Ambiente para Produção
# ==============================================================================
# Copie este arquivo para .env e preencha com os valores corretos
# NUNCA commite o arquivo .env com credenciais reais!
# ==============================================================================

# ==============================================================================
# Database Configuration (PostgreSQL no Docker Compose)
# ==============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=enviafolha_db
DB_USER=enviafolha_user
DB_PASSWORD=change-this-secure-password-in-production

# ==============================================================================
# Evolution API (WhatsApp Integration)
# ==============================================================================
EVOLUTION_SERVER_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-api-key-here
EVOLUTION_INSTANCE_NAME=your-instance-name

# ==============================================================================
# JWT Authentication
# ==============================================================================
# Gere uma chave secreta forte: openssl rand -hex 32
SECRET_KEY=change-this-in-production-use-strong-random-secret-key-minimum-32-chars

# ==============================================================================
# Application Configuration
# ==============================================================================
LOG_LEVEL=info
PORT=8002
API_URL=http://localhost:8002/api/v1

# ==============================================================================
# Docker Hub (para build e push)
# ==============================================================================
DOCKER_USERNAME=lucasplcorrea
TAG=latest

# ==============================================================================
# Optional: PgAdmin (se usar)
# ==============================================================================
PGADMIN_DEFAULT_EMAIL=admin@nexorh.local
PGADMIN_DEFAULT_PASSWORD=admin

# ==============================================================================
# Notas de Segurança
# ==============================================================================
# 1. Sempre use senhas fortes em produção
# 2. Nunca exponha credenciais em repositórios públicos
# 3. Use Docker secrets ou ferramentas de gestão de segredos em produção
# 4. Considere usar variáveis de ambiente do sistema operacional
# 5. Em cloud providers, use serviços de secrets management (AWS Secrets Manager, etc)
