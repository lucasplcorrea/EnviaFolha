# Database Configuration
DATABASE_URL=sqlite:///./nexo_rh.db
# Para PostgreSQL em produção:
# DATABASE_URL=postgresql://user:password@localhost:5432/nexo_rh

# JWT Authentication
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Evolution API Configuration - Primary Instance (Required)
EVOLUTION_SERVER_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-api-key-here
EVOLUTION_INSTANCE_NAME=RH-Abecker

# Evolution API - Additional Instances (Optional, for multi-instance round-robin)
# Uncomment and configure to enable anti-softban with multiple WhatsApp numbers
# EVOLUTION_INSTANCE_NAME2=RH-Segunda
# EVOLUTION_INSTANCE_NAME3=RH-Terceira

# Email Configuration (Optional, for future email delivery)
# SMTP_HOST= 
# SMTP_PORT= 
# SMTP_USER=
# SMTP_PASSWORD= 
# SMTP_FROM= 
# SMTP_USE_TLS=t 

# File Upload Configuration
MAX_FILE_SIZE=26214400  # 25MB in bytes
UPLOAD_DIR=uploads
PROCESSED_DIR=processed
SENT_DIR=enviados

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO

# Maintenance Scripts Configuration (Optional)
# Used by scripts in backend/scripts/maintenance
# API endpoint used by maintenance scripts (defaults to local API)
# SCRIPT_API_URL=https://api.seu-dominio.com

# API credentials used by maintenance scripts that call /auth/login
# Keep this password strong and rotate periodically
# SCRIPT_API_USERNAME=admin
# SCRIPT_API_PASSWORD=trocar-por-senha-forte

# Optional override for CSV directory used by reprocess scripts
# If omitted, scripts use ../Analiticos/Empreendimentos relative to project root
# SCRIPT_ANALYTICS_DIR=/data/enviafolha/Analiticos/Empreendimentos

# Password migration script (backend/scripts/maintenance/migrate_user_passwords.py)
# JSON map: username -> plain password to generate new bcrypt hash
# Example:
# PASSWORD_MIGRATION_MAP={"admin":"SenhaAdminForte","operador.rh":"SenhaOperadorForte"}

# Optional fallback password for users not present in PASSWORD_MIGRATION_MAP
# If omitted, users without explicit mapping are skipped during migration
# DEFAULT_MIGRATION_PASSWORD=trocar-por-senha-temporaria-forte

# Production sync helper (backend/scripts/maintenance/sync_employees_from_production.py)
# Required only when using that script to sync production -> another DB
# PROD_DB_HOST=host-do-banco-producao
# PROD_DB_PORT=5432
# PROD_DB_NAME=enviafolha_db
# PROD_DB_USER=enviafolha_user
# PROD_DB_PASSWORD=trocar-por-senha-forte
